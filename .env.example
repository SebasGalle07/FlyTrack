# Variables de entorno para docker-compose
# Copiar como .env y ajustar los valores

# CORS: orígenes adicionales (separados por coma)
# Ejemplo: http://54.123.45.67:5173,http://mi-dominio.com
CORS_ORIGINS=http://<IP_EC2>:5173

# Tags de las imágenes Docker (se configuran automáticamente por el pipeline)
TAG_BACKEND=latest
TAG_FRONTEND=latest
